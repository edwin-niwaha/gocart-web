{
  "name": "gocart_web",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev",
    "build": "node ./node_modules/next/dist/bin/next build",
    "start": "node ./node_modules/next/dist/bin/next start",
    "lint": "node ./node_modules/next/dist/bin/next lint",
    "typecheck": "node ./node_modules/typescript/bin/tsc --noEmit --incremental false",
    "type-check": "npm run typecheck",
    "test": "npm run test:security && npm run test:api",
    "test:security": "node scripts/security-tests.js",
    "test:api": "node scripts/api-contract-tests.js",
    "validate:env": "node scripts/validate-env.js",
    "release:check": "npm run validate:env && npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "axios": "1.15.2",
    "clsx": "^2.1.1",
    "lucide-react": "^0.511.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.54.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
