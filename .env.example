# API
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_API_TIMEOUT_MS=15000
NEXT_PUBLIC_TENANT_SLUG=gocart
NEXT_PUBLIC_TENANT_ROOT_DOMAIN=
NEXT_PUBLIC_TENANT_DOMAIN_MAP=
NEXT_PUBLIC_REQUIRE_TENANT=true
NEXT_PUBLIC_ALLOW_TENANT_OVERRIDE=false
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_ALLOW_INSECURE_API=false
NEXT_PUBLIC_IMAGE_HOSTNAMES=api.example.com

# Optional compatibility fallback used in some image URL helpers
NEXT_PUBLIC_API_URL=

# App
NEXT_PUBLIC_APP_NAME=GoCart
NEXT_PUBLIC_SITE_URL=https://app.example.com

# Auth / analytics
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_GA_ID=
